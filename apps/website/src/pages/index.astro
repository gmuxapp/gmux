---
import heroDesktop from '../assets/hero-desktop.png'
import heroMobile from '../assets/hero-mobile.png'
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>gmux — see every running process in your browser</title>
  <meta name="description" content="Prefix any command with gmuxr and it shows up in a live browser dashboard. Check on AI agents, test suites, and builds from your desktop or your phone." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">gmux</a>
      <div class="nav-links">
        <a href="/quick-start/">Docs</a>
        <a href="https://github.com/gmuxapp/gmux" class="nav-github" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>See every running process in&nbsp;your&nbsp;browser</h1>
        <p class="hero-sub">
          Prefix any command with <code>gmuxr</code> and it appears
          in a live dashboard. Your terminal stays yours.
          Check in from your desktop or&nbsp;your&nbsp;phone.
        </p>
        <div class="hero-install">
          <div class="install-cmd" id="install-cmd">
            <code>brew install gmuxapp/tap/gmux</code>
            <button class="copy-btn" id="copy-btn" aria-label="Copy to clipboard">
              <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/quick-start/" class="hero-cta">Quick start</a>
          <a href="https://github.com/gmuxapp/gmux" class="hero-secondary">Source on GitHub</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-stage">
          <img
            class="hero-desktop-shot"
            src={heroDesktop.src}
            alt=""
            width={heroDesktop.width}
            height={heroDesktop.height}
            loading="eager"
          />
          <img
            class="hero-mobile-shot"
            src={heroMobile.src}
            alt=""
            width={heroMobile.width}
            height={heroMobile.height}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" id="how">
    <div class="section-inner">
      <h2>How it works</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-body">
            <h3>Prefix any command</h3>
            <p>
              Put <code>gmuxr</code> in front of whatever you want to monitor.
              The command runs normally. Nothing about its behavior&nbsp;changes.
            </p>
            <div class="code-block"><code>gmuxr pytest tests/ -v</code></div>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-body">
            <h3>Open the dashboard</h3>
            <p>
              Every session shows up at <code>localhost:8790</code>,
              organized by project folder. Open it on any device with&nbsp;a&nbsp;browser.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-body">
            <h3>Nothing else changes</h3>
            <p>
              <code>gmux</code> is not a terminal replacement. Keep using iTerm, Kitty, WezTerm, tmux.
              The browser is just a second&nbsp;view.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zero friction -->
  <section class="section section-alt" id="friction">
    <div class="section-inner">
      <h2>Fits into what you already do</h2>
      <p class="section-lead">No new workflow. No configuration. Just more&nbsp;visibility.</p>
      <div class="features">
        <div class="feature">
          <h3>Alias and forget</h3>
          <p>
            Add <code>gmuxr</code> to a shell alias and every invocation
            shows up in the dashboard&nbsp;automatically.
          </p>
          <div class="code-block"><code>alias cc="gmuxr claude"</code></div>
        </div>
        <div class="feature">
          <h3>Works with everything</h3>
          <p>
            AI agents, test suites, dev servers, build scripts.
            If it runs in a terminal, <code>gmux</code> can&nbsp;show&nbsp;it.
          </p>
        </div>
        <div class="feature">
          <h3>Nothing to configure</h3>
          <p>
            One <code>brew install</code>, secure defaults works&nbsp;out&nbsp;of&nbsp;the&nbsp;box.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">gmux</span>
      <div class="footer-links">
        <a href="/quick-start/">Docs</a>
        <a href="https://github.com/gmuxapp/gmux">GitHub</a>
        <span class="footer-sep">&middot;</span>
        <span class="footer-license">MIT License</span>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('copy-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText('brew install gmuxapp/tap/gmux')
      const copyIcon = document.querySelector('.copy-icon')
      const checkIcon = document.querySelector('.check-icon')
      if (copyIcon && checkIcon) {
        copyIcon.style.display = 'none'
        checkIcon.style.display = 'block'
        setTimeout(() => {
          copyIcon.style.display = 'block'
          checkIcon.style.display = 'none'
        }, 2000)
      }
    })
  </script>
</body>
</html>

<style>
  :where(*, *::before, *::after) {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: oklch(12% 0.015 250);
    --bg-alt: oklch(15% 0.015 250);
    --text: oklch(88% 0.01 250);
    --text-secondary: oklch(65% 0.01 250);
    --text-muted: oklch(48% 0.01 250);
    --accent: oklch(72% 0.1 195);
    --border: oklch(22% 0.015 250);
    --border-subtle: oklch(18% 0.01 250);
    --code-bg: oklch(16% 0.015 250);
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Source Sans 3', 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }

  h1, h2, h3 {
    font-family: 'Instrument Sans', sans-serif;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  code {
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }

  .brand {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  /* --- Nav --- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(12% 0.015 250 / 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--text);
    letter-spacing: -0.04em;
  }
  .nav-logo:hover { text-decoration: none; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  .nav-github { display: flex; align-items: center; color: var(--text-muted) !important; }
  .nav-github:hover { color: var(--text) !important; }

  /* --- Hero --- */
  .hero {
    padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(2rem, 5vw, 3.5rem);
  }

  .hero-content {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 3.5vw, 3.5rem);
    align-items: center;
  }

  .hero-text {
    max-width: 36rem;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
    line-height: 1.05;
    text-wrap: balance;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.15vw, 1.12rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 40ch;
  }

  .hero-install {
    margin-bottom: 1rem;
  }

  .install-cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.65rem 0.5rem 0.85rem;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
  }

  .install-cmd code { font-size: inherit; }

  .copy-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .copy-btn:hover { color: var(--text); }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
  }

  .hero-cta {
    position: relative;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--bg);
    background: var(--text);
    padding: 0.62rem 1.1rem;
    border-radius: 8px;
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 1px 3px oklch(4% 0.01 250 / 0.3);
    transition:
      color 0.35s var(--ease-out-expo),
      box-shadow 0.5s var(--ease-out-expo),
      transform 0.5s var(--ease-out-expo);
  }
  /* Layer 1: teal gradient fill, wipes in from left */
  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(52% 0.14 190), oklch(42% 0.16 225));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
    z-index: -1;
  }
  /* Layer 2: bright streak sweeps across, delayed */
  .hero-cta::after {
    content: '';
    position: absolute;
    top: 0;
    left: -130%;
    width: 80%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      oklch(100% 0 200 / 0.18) 38%,
      oklch(100% 0 200 / 0.45) 50%,
      oklch(100% 0 200 / 0.18) 62%,
      transparent 80%
    );
    z-index: 1;
    pointer-events: none;
    transition: none;
  }
  .hero-cta:hover {
    color: oklch(97% 0.02 195);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow:
      0 0 20px oklch(52% 0.14 195 / 0.4),
      0 0 50px oklch(48% 0.12 210 / 0.18),
      0 8px 20px oklch(4% 0.01 250 / 0.35);
  }
  .hero-cta:hover::before {
    transform: scaleX(1);
  }
  .hero-cta:hover::after {
    left: 160%;
    transition: left 0.7s 0.22s var(--ease-out-expo);
  }

  .hero-secondary {
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .hero-secondary:hover { color: var(--text); text-decoration: none; }

  /* Hero visual — fixed-ratio composition */
  .hero-visual {
    min-width: 0;
  }

  .hero-stage {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin-left: auto;
    /* bottom padding reserves space for the phone overhang */
    padding-bottom: 4%;
  }

  .hero-stage::before {
    content: '';
    position: absolute;
    inset: 10% 10% 14% 12%;
    background: radial-gradient(
      circle at 45% 40%,
      oklch(16% 0.018 250 / 0.6),
      transparent 70%
    );
    filter: blur(28px);
    pointer-events: none;
  }

  .hero-desktop-shot,
  .hero-mobile-shot {
    display: block;
    height: auto;
    position: relative;
  }

  .hero-desktop-shot {
    width: 100%;
    border-radius: 4px;
    border: 1px solid oklch(100% 0 0 / 0.08);
    box-shadow: 0 24px 60px oklch(4% 0.01 250 / 0.4);
  }

  /* Phone: sized as a fixed percentage of desktop so they scale together */
  .hero-mobile-shot {
    position: absolute;
    width: 35%;
    right: -1rem;
    bottom: 0;
    border-radius: 16px;
    border: clamp(4px, 1.2vw, 10px) solid oklch(20% 0.01 250);
    box-shadow: 0 18px 50px oklch(4% 0.01 250 / 0.75);
  }

  /* --- Sections --- */
  .section {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .section-alt {
    background: var(--bg-alt);
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
  }

  .section h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-lead {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 50ch;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 2.5rem;
  }

  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .step-body h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .step-body p {
    color: var(--text-secondary);
    max-width: 48ch;
    line-height: 1.65;
  }

  .code-block {
    margin-top: 0.75rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.85rem;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
    display: inline-block;
  }

  /* Features grid */
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .feature p {
    color: var(--text-secondary);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  /* --- Footer --- */
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: -0.04em;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.85rem;
  }
  .footer-links a { color: var(--text-secondary); }
  .footer-sep { color: var(--text-muted); }
  .footer-license { color: var(--text-muted); }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero h1 { font-size: 2.4rem; }
    .hero-stage { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .hero { padding-top: 2.4rem; }
    .hero h1 { font-size: 2rem; }
    .hero-sub { font-size: 1rem; }

    .install-cmd {
      width: 100%;
      justify-content: space-between;
      padding-right: 0.65rem;
    }

    .install-cmd code {
      white-space: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .install-cmd code::-webkit-scrollbar { display: none; }

    /* Steps: keep number beside text, just shrink the number */
    .step-num { width: 28px; height: 28px; font-size: 0.8rem; }


    .footer-links { font-size: 0.8rem; gap: 0.6rem; }
  }

  /* --- Animations --- */
  @media (prefers-reduced-motion: no-preference) {
    .hero-text { animation: fadeUp 0.5s var(--ease-out-expo) both; }
    .hero-visual { animation: fadeUp 0.6s 0.1s var(--ease-out-expo) both; }
    .section { animation: fadeUp 0.5s var(--ease-out-expo) both; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
