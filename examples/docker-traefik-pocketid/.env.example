# Your domain (gmux will be at gmux.DOMAIN, PocketID at auth.DOMAIN)
DOMAIN=example.com

# Let's Encrypt email
ACME_EMAIL=you@example.com

# Cloudflare DNS API token (for Let's Encrypt DNS challenge)
# See https://doc.traefik.io/traefik/https/acme/ for other providers
CF_DNS_API_TOKEN=your-cloudflare-token

# PocketID OIDC client credentials
# Create a client in PocketID at https://auth.DOMAIN/settings/admin/oidc-clients
# Callback URL: https://gmux.DOMAIN/_auth/callback
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Random secret for forward-auth session encryption
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me

# gmux bearer token
# Generate with: openssl rand -hex 32
# Written to disk on first start; must match on subsequent starts.
GMUX_TOKEN=change-me
