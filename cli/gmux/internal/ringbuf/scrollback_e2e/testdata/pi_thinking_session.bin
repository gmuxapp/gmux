 [3m[38;2;128;128;128mSimple Python function request.[39m[23m                                                                                        [0m]8;;
[0m]8;;
 [38;2;128;128;128m```python[39m                                                                                                              [0m]8;;
   [38;2;220;220;170m[38;2;86;156;214mdef[39m [38;2;220;220;170mis_prime[39m([38;2;156;220;254mn: [38;2;78;201;176mint[39m[39m) -> [38;2;78;201;176mbool[39m:[39m                                                                                        [0m]8;;
       [38;2;206;145;120m"""                                                                                                              [0m]8;;
       Check if a number is prime.                                                                                      [0m]8;;
                                                                                                                        [0m]8;;
       A prime number is a natural number greater than 1 that has no positive                                           [0m]8;;
       divisors other than 1 and itself.                                                                                [0m]8;;
                                                                                                                        [0m]8;;
       Args:                                                                                                            [0m]8;;
           n: The integer to check.                                                                                     [0m]8;;
                                                                                                                        [0m]8;;
       Returns:                                                                                                         [0m]8;;
           True if n is prime, False otherwise.                                                                         [0m]8;;
                                                                                                                        [0m]8;;
       Examples:                                                                                                        [0m]8;;
           >>> is_prime(2)                                                                                              [0m]8;;
           True                                                                                                         [0m]8;;
           >>> is_prime(17)                                                                                             [0m]8;;
           True                                                                                                         [0m]8;;
           >>> is_prime(1)                                                                                              [0m]8;;
           False                                                                                                        [0m]8;;
           >>> is_prime(-5)                                                                                             [0m]8;;
           False                                                                                                        [0m]8;;
           >>> is_prime(9)                                                                                              [0m]8;;
           False                                                                                                        [0m]8;;
       """[39m                                                                                                              [0m]8;;
       [38;2;106;153;85m# Edge cases: primes must be greater than 1[39m                                                                      [0m]8;;
       [38;2;86;156;214mif[39m n < [38;2;181;206;168m2[39m:                                                                                                        [0m]8;;
           [38;2;86;156;214mreturn[39m [38;2;181;206;168mFalse[39m                                                                                                 [0m]8;;
                                                                                                                        [0m]8;;
       [38;2;106;153;85m# 2 is the only even prime[39m                                                                                       [0m]8;;
       [38;2;86;156;214mif[39m n == [38;2;181;206;168m2[39m:                                                                                                       [0m]8;;
           [38;2;86;156;214mreturn[39m [38;2;181;206;168mTrue[39m                                                                                                  [0m]8;;
                                                                                                                        [0m]8;;
       [38;2;106;153;85m# Eliminate even numbers and multiples of 2[39m                                                                      [0m]8;;
       [38;2;86;156;214mif[39m n % [38;2;181;206;168m2[39m == [38;2;181;206;168m0[39m:                                                                                                   [0m]8;;
           [38;2;86;156;214mreturn[39m [38;2;181;206;168mFalse[39m                                                                                                 [0m]8;;
                                                                                                                        [0m]8;;
       [38;2;106;153;85m# Check odd divisors up to sqrt(n)[39m                                                                               [0m]8;;
       [38;2;106;153;85m# If n has a factor larger than sqrt(n), the corresponding factor is smaller,[39m                                    [0m]8;;
       [38;2;106;153;85m# so we would have already found it.[39m                                                                             [0m]8;;
       i = [38;2;181;206;168m3[39m                                                                                                            [0m]8;;
       [38;2;86;156;214mwhile[39m i * i <= n:                                                                                                [0m]8;;
           [38;2;86;156;214mif[39m n % i == [38;2;181;206;168m0[39m:                                                                                               [0m]8;;
               [38;2;86;156;214mreturn[39m [38;2;181;206;168mFalse[39m                                                                                             [0m]8;;
           i += [38;2;181;206;168m2[39m                                                                                                       [0m]8;;
                                                                                                                        [0m]8;;
       [38;2;86;156;214mreturn[39m [38;2;181;206;168mTrue[39m                                                                                                      [0m]8;;
 [38;2;128;128;128m```[39m                                                                                                                    [0m]8;;
                                                                                                                        [0m]8;;
 [1mKey design decisions:[22m                                                                                                  [0m]8;;
                                                                                                                        [0m]8;;
 [38;2;138;190;183m- [39m[1mTime complexity:[22m O(√n) by only checking up to the square root of [38;2;138;190;183mn[39m                                                   [0m]8;;
 [38;2;138;190;183m- [39m[1mEarly exits:[22m Handle even numbers before the loop, cutting iterations in half                                         [0m]8;;
 [38;2;138;190;183m- [39m[1mEdge cases covered:[22m                                                                                                  [0m]8;;
     [38;2;138;190;183m- [39m[38;2;138;190;183mn < 2[39m (0, 1, negatives) → [38;2;138;190;183mFalse[39m                                                                                  [0m]8;;
     [38;2;138;190;183m- [39m[38;2;138;190;183mn = 2[39m → [38;2;138;190;183mTrue[39m (smallest prime, also even)                                                                         [0m]8;;
     [38;2;138;190;183m- [39mEven numbers > 2 → [38;2;138;190;183mFalse[39m                                                                                         [0m]8;;
     [38;2;138;190;183m- [39mPerfect squares like 9, 25 → correctly [38;2;138;190;183mFalse[39m                                                                     [0m]8;;
