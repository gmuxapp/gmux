---
import heroDesktop from '../assets/hero-desktop.png'
import heroMobile from '../assets/hero-mobile.png'
import PostHog from '../components/posthog.astro'
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <PostHog />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>gmux — see every running process in your browser</title>
  <meta name="description" content="Prefix any command with gmux and it shows up in a live browser dashboard. Check on AI agents, test suites, and builds from your desktop or your phone." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">gmux</a>
      <div class="nav-links">
        <a href="/quick-start/">Docs</a>
        <a href="https://github.com/gmuxapp/gmux" class="nav-github" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>See every running process in&nbsp;your&nbsp;browser</h1>
        <p class="hero-sub">
          Prefix any command with <code>gmux</code> and it appears
          in a live browser dashboard. It runs alongside your existing terminal.
          Check in from your desktop or&nbsp;your&nbsp;phone.
        </p>
        <div class="hero-install">
          <div class="install-box">
            <div class="install-tabs" id="install-tabs">
              <button class="tab-btn active" data-os="mac">macOS</button>
              <button class="tab-btn" data-os="linux">Linux</button>
            </div>
            <div class="install-cmd" id="install-cmd">
              <code data-cmd-mac="brew install gmuxapp/tap/gmux" data-cmd-linux="curl -sSfL https://gmux.app/install.sh | sh">brew install gmuxapp/tap/gmux</code>
              <button class="copy-btn" id="copy-btn" aria-label="Copy to clipboard">
                <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
          <a class="script-link" href="/install.sh">What does this script do?</a>
        </div>
        <div class="hero-actions">
          <a href="/quick-start/" class="hero-cta">Quick start</a>
          <a href="https://github.com/gmuxapp/gmux" class="hero-secondary">Source on GitHub</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-stage">
          <img
            class="hero-desktop-shot"
            src={heroDesktop.src}
            alt=""
            width={heroDesktop.width}
            height={heroDesktop.height}
            loading="eager"
          />
          <img
            class="hero-mobile-shot"
            src={heroMobile.src}
            alt=""
            width={heroMobile.width}
            height={heroMobile.height}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" id="how">
    <div class="section-inner">
      <h2>How it works</h2>
      <div class="steps-row">
        <div class="step-card">
          <div class="step-num">1</div>
          <h3>Prefix any command</h3>
          <p>
            Put <code>gmux</code> in front of whatever you want to&nbsp;monitor.
          </p>
          <div class="code-block"><code>gmux pytest tests/ -v</code></div>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h3>Sessions appear instantly</h3>
          <p>
            Every process shows up at <code>localhost:8790</code>,
            grouped by project&nbsp;folder.
          </p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h3>Check in from anywhere</h3>
          <p>
            Open the dashboard on your phone, a tablet, or another machine.
            No install needed on the viewing&nbsp;device.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Zero friction -->
  <section class="section section-alt" id="friction">
    <div class="section-inner">
      <h2>Fits into what you already do</h2>
      <p class="section-lead">No new workflow. No configuration. Just more&nbsp;visibility.</p>
      <div class="features">
        <div class="feature">
          <h3>Alias and forget</h3>
          <p>
            Add <code>gmux</code> to a shell alias and every invocation
            shows up in the dashboard&nbsp;automatically.
          </p>
          <div class="code-block"><code>alias cc="gmux claude"</code></div>
        </div>
        <div class="feature">
          <h3>Works with everything</h3>
          <p>
            AI agents, test suites, dev servers, build scripts.
            If it runs in a terminal, <code>gmux</code> can&nbsp;show&nbsp;it.
          </p>
        </div>
        <div class="feature">
          <h3>Nothing to configure</h3>
          <p>
            One install command, secure defaults works&nbsp;out&nbsp;of&nbsp;the&nbsp;box.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="section cta-section">
    <div class="section-inner cta-inner">
      <h2>Try it in two&nbsp;minutes</h2>
      <div class="cta-install">
        <div class="install-box">
          <div class="install-tabs" id="install-tabs-bottom">
            <button class="tab-btn active" data-os="mac">macOS</button>
            <button class="tab-btn" data-os="linux">Linux</button>
          </div>
          <div class="install-cmd" id="install-cmd-bottom">
            <code data-cmd-mac="brew install gmuxapp/tap/gmux" data-cmd-linux="curl -sSfL https://gmux.app/install.sh | sh">brew install gmuxapp/tap/gmux</code>
            <button class="copy-btn" id="copy-btn-bottom" aria-label="Copy to clipboard">
              <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <a class="script-link" href="/install.sh">What does this script do?</a>
      </div>
      <a href="/quick-start/" class="hero-cta">Quick start</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">gmux</span>
      <div class="footer-links">
        <a href="/quick-start/">Docs</a>
        <a href="https://github.com/gmuxapp/gmux">GitHub</a>
        <span class="footer-sep">&middot;</span>
        <span class="footer-license">MIT License</span>
      </div>
      <div class="footer-socials">
        <a href="https://bsky.app/profile/mgabor.hu" aria-label="Bluesky" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 568 501" fill="currentColor"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 57.947c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 323.8 536.444 388.56 473.333 453.32c-119.86 122.992-172.272-30.859-185.702-70.281-2.462-7.227-3.614-10.608-3.631-7.733-.017-2.875-1.169.506-3.631 7.733-13.43 39.422-65.842 193.273-185.702 70.281-63.111-64.76-33.889-129.52 80.986-149.071-65.72 11.185-139.6-7.295-159.875-79.748C9.945 203.659 0 75.291 0 57.946 0-28.906 76.135-1.612 123.121 33.664Z"/></svg>
        </a>
        <a href="https://x.com/mgabor_" aria-label="X" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://ko-fi.com/mgabor" aria-label="Ko-fi" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/></svg>
        </a>
      </div>
    </div>
  </footer>

  <script>
    const commands = {
      mac: 'brew install gmuxapp/tap/gmux',
      linux: 'curl -sSfL https://gmux.app/install.sh | sh',
    }

    // Detect OS from user agent
    function detectOS() {
      const ua = navigator.userAgent || navigator.platform || ''
      if (/Linux/.test(ua)) return 'linux'
      return 'mac'
    }

    // Switch all tab groups to a given OS
    function switchOS(os) {
      document.querySelectorAll('.install-tabs').forEach(tabs => {
        tabs.querySelectorAll('.tab-btn').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.os === os)
        })
      })
      document.querySelectorAll('.install-cmd code[data-cmd-mac]').forEach(code => {
        code.textContent = commands[os]
      })
      document.querySelectorAll('.script-link').forEach(link => {
        link.style.visibility = os === 'linux' ? 'visible' : 'hidden'
      })
    }

    // Reorder tabs so the detected OS comes first
    function reorderTabs(os) {
      document.querySelectorAll('.install-tabs').forEach(tabs => {
        const btns = [...tabs.querySelectorAll('.tab-btn')]
        const first = btns.find(b => b.dataset.os === os)
        if (first && first !== btns[0]) {
          tabs.insertBefore(first, btns[0])
        }
      })
    }

    // Wire up tab clicks (synced across both tab groups)
    document.querySelectorAll('.install-tabs .tab-btn').forEach(btn => {
      btn.addEventListener('click', () => switchOS(btn.dataset.os))
    })

    // Copy button
    function setupCopyBtn(id) {
      const btn = document.getElementById(id)
      if (!btn) return
      btn.addEventListener('click', () => {
        const code = btn.closest('.install-cmd').querySelector('code')
        navigator.clipboard.writeText(code.textContent)
        const copy = btn.querySelector('.copy-icon')
        const check = btn.querySelector('.check-icon')
        if (copy && check) {
          copy.style.display = 'none'
          check.style.display = 'block'
          setTimeout(() => {
            copy.style.display = 'block'
            check.style.display = 'none'
          }, 2000)
        }
      })
    }
    setupCopyBtn('copy-btn')
    setupCopyBtn('copy-btn-bottom')

    // Auto-detect on load
    const detected = detectOS()
    reorderTabs(detected)
    switchOS(detected)

    // Reveal after OS detection to avoid flash of wrong command
    document.querySelectorAll('.install-box').forEach(box => {
      box.classList.add('ready')
    })
  </script>
</body>
</html>

<style>
  :where(*, *::before, *::after) {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: oklch(12% 0.015 250);
    --bg-alt: oklch(15% 0.015 250);
    --text: oklch(88% 0.01 250);
    --text-secondary: oklch(65% 0.01 250);
    --text-muted: oklch(48% 0.01 250);
    --accent: oklch(72% 0.1 195);
    --border: oklch(22% 0.015 250);
    --border-subtle: oklch(18% 0.01 250);
    --code-bg: oklch(16% 0.015 250);
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Source Sans 3', 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }

  h1, h2, h3 {
    font-family: 'Instrument Sans', sans-serif;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  code {
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .code-block code {
    background: none;
    padding: 0;
  }

  .brand {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  /* --- Nav --- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(12% 0.015 250 / 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--text);
    letter-spacing: -0.04em;
  }
  .nav-logo:hover { text-decoration: none; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  .nav-github { display: flex; align-items: center; color: var(--text-muted) !important; }
  .nav-github:hover { color: var(--text) !important; }

  /* --- Hero --- */
  .hero {
    padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(2rem, 5vw, 3.5rem);
  }

  .hero-content {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 3.5vw, 3.5rem);
    align-items: center;
  }

  .hero-text {
    max-width: 36rem;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
    line-height: 1.05;
    text-wrap: balance;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.15vw, 1.12rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 40ch;
  }

  .hero-install {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .install-box {
    display: inline-flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--code-bg);
    opacity: 0;
  }

  .install-box.ready {
    opacity: 1;
    transition: opacity 0.15s;
  }

  .install-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
  }

  .tab-btn {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    position: relative;
    transition: color 0.15s;
  }

  .tab-btn.active {
    color: var(--text);
    background: oklch(18% 0.015 250);
  }

  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: oklch(18% 0.015 250);
  }

  .tab-btn:hover:not(.active) {
    color: var(--text-secondary);
  }

  .script-link {
    visibility: hidden;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
  }

  .script-link:hover {
    color: var(--text-secondary);
  }

  .install-cmd {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: oklch(18% 0.015 250);
    padding: 0.55rem 0.65rem 0.55rem 0.85rem;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
  }

  .install-cmd code {
    font-size: inherit;
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .copy-btn:hover { color: var(--text); }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
  }

  .hero-cta {
    position: relative;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--bg);
    background: var(--text);
    padding: 0.62rem 1.1rem;
    border-radius: 8px;
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 1px 3px oklch(4% 0.01 250 / 0.3);
    transition:
      color 0.35s var(--ease-out-expo),
      box-shadow 0.5s var(--ease-out-expo),
      transform 0.5s var(--ease-out-expo);
  }
  /* Layer 1: teal gradient fill, wipes in from left */
  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(52% 0.14 190), oklch(42% 0.16 225));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
    z-index: -1;
  }
  /* Layer 2: bright streak sweeps across, delayed */
  .hero-cta::after {
    content: '';
    position: absolute;
    top: 0;
    left: -130%;
    width: 80%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      oklch(100% 0 200 / 0.18) 38%,
      oklch(100% 0 200 / 0.45) 50%,
      oklch(100% 0 200 / 0.18) 62%,
      transparent 80%
    );
    z-index: 1;
    pointer-events: none;
    transition: none;
  }
  .hero-cta:hover {
    color: oklch(97% 0.02 195);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow:
      0 0 20px oklch(52% 0.14 195 / 0.4),
      0 0 50px oklch(48% 0.12 210 / 0.18),
      0 8px 20px oklch(4% 0.01 250 / 0.35);
  }
  .hero-cta:hover::before {
    transform: scaleX(1);
  }
  .hero-cta:hover::after {
    left: 160%;
    transition: left 0.7s 0.22s var(--ease-out-expo);
  }

  .hero-secondary {
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .hero-secondary:hover { color: var(--text); text-decoration: none; }

  /* Hero visual — fixed-ratio composition */
  .hero-visual {
    min-width: 0;
  }

  .hero-stage {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin-left: auto;
    /* bottom padding reserves space for the phone overhang */
    padding-bottom: 4%;
  }

  .hero-stage::before {
    content: '';
    position: absolute;
    inset: 10% 10% 14% 12%;
