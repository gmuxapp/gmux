#!/usr/bin/env bash
set -Eeuo pipefail
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR

# gmux dev — run all services with watch/HMR
#
# Services:
#   gmuxd     (Go, port 8790)  — watchexec auto-restart on .go change
#   gmux-api  (TS, port 8787)  — tsx watch auto-restart
#   gmux-web  (TS, port 5173)  — vite HMR
#   gmuxr     (Go)             — watchexec auto-restart, launches pi

cd "$(dirname "$0")"

cleanup() {
  echo ""
  echo "shutting down..."
  kill 0 2>/dev/null
  wait 2>/dev/null
}
trap cleanup EXIT

# Colors for log prefixes
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

prefix() {
  local color="$1" name="$2"
  sed -u "s/^/$(printf "${color}[${name}]${NC} ")/"
}

echo "Starting gmux dev environment..."
echo ""

# 1. gmuxd — session daemon
(cd services/gmuxd && watchexec -r -e go -- go run ./cmd/gmuxd) 2>&1 | prefix "$RED" "gmuxd" &

# Wait for gmuxd to be ready
for i in $(seq 1 30); do
  if curl -sf http://localhost:8790/v1/health >/dev/null 2>&1; then
    break
  fi
  sleep 0.2
done

# 2. gmux-api — tRPC/SSE proxy
(cd apps/gmux-api && pnpm exec tsx watch src/server.ts) 2>&1 | prefix "$GREEN" "api" &

# 3. gmux-web — Vite dev server with HMR
(cd apps/gmux-web && pnpm exec vite) 2>&1 | prefix "$BLUE" "web" &

# 4. gmuxr — runner with pi session
sleep 1
(cd cli/gmuxr && watchexec -r -e go -- go run ./cmd/gmuxr -- pi) 2>&1 | prefix "$YELLOW" "gmuxr" &

echo ""
echo "  gmux-web  → http://localhost:5173"
echo "  gmux-api  → http://localhost:8787"
echo "  gmuxd     → http://localhost:8790"
echo ""
echo "Press Ctrl+C to stop all services"
echo ""

wait
