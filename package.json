{
  "name": "@gmux/root",
  "private": true,
  "version": "0.1.0",
  "description": "gmux monorepo",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "moon run :build",
    "dev": "./scripts/dev-kill.sh && moon run :dev",
    "test": "moon run :test",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "lint": "biome lint . && moon run :lint",
    "check": "moon check :build :test",
    "graph": "moon project-graph"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "darwin",
        "linux",
        "current"
      ],
      "cpu": [
        "arm64",
        "x64",
        "current"
      ],
      "libc": [
        "glibc",
        "current"
      ]
    },
    "patchedDependencies": {
      "@wterm/ghostty@0.3.0": "patches/@wterm__ghostty@0.3.0.patch",
      "@pierre/diffs@1.2.4": "patches/@pierre__diffs@1.2.4.patch"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@moonrepo/cli": "^2.0.4",
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "typescript": "^5.8.2"
  }
}
